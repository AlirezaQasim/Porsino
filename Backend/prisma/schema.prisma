generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// مدل کاربر
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// مدل سوالات کنکور
model Question {
  id            Int      @id @default(autoincrement())
  text          String   @db.Text // برای متن‌های طولانی
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctOption String   // A, B, C, or D
  explanation   String   @db.Text
  topic         String
  subTopic      String?
  difficulty    Difficulty @default(MEDIUM)
  year          Int
  createdAt     DateTime @default(now())
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}